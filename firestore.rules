rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user doc
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isWholesaler() {
      return isAuth() && getUserData().role == 'wholesaler';
    }

    function isRetailer() {
      return isAuth() && getUserData().role == 'retailer';
    }

    function isDelivery() {
      return isAuth() && getUserData().role == 'delivery';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isWholesaler();
      allow update: if isWholesaler() || request.auth.uid == userId;
      allow delete: if isWholesaler();
    }

    // Products collection
    match /products/{productId} {
      allow read: if isAuth();
      allow create, update, delete: if isWholesaler();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuth() && (
        isWholesaler()
        || resource.data.retailerId == request.auth.uid
        || resource.data.assignedDeliveryId == request.auth.uid
      );
      allow create: if isAuth() && (isRetailer() || isWholesaler());
      allow update: if isAuth() && (
        isWholesaler()
        || (isDelivery() && resource.data.assignedDeliveryId == request.auth.uid)
        || (isRetailer() && resource.data.retailerId == request.auth.uid
            && request.resource.data.status == 'delivered')
      );
      allow delete: if false;
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuth();
      allow create: if isAuth() && isWholesaler();
      allow update, delete: if false;
    }

    // Activity logs
    match /activityLogs/{logId} {
      allow read: if isWholesaler();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Settings (wholesaler-only)
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isWholesaler();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
